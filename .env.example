# Copy to .env and fill in.
DISCORD_TOKEN=your-bot-token-here

# Optional: server id -> instant slash-command sync (omit for global, ~1h to appear)
# GUILD_ID=

# --- How often the bot may speak -------------------------------------------
# Min seconds between cards per channel. Higher = quieter bot.
SLANG_COOLDOWN=20

# --- How the bot learns from Urban Dictionary ------------------------------
# Sightings of an unknown word before the bot probes UD (re-probes every
# LEARN_HITS after). Lower = learns faster but easier for one user to game.
LEARN_HITS=3
# Min UD net votes (up - down) required to auto-learn a word.
LEARN_MIN_NET=150
# Optional: min up/(up+down) ratio, 0..1. Blocks controversial/downvoted words.
# 0 disables the check (default).
LEARN_MIN_RATIO=0

# Where the learned-word DB lives. In Docker this is set to /data/slang.db.
# SLANG_DB=./slang.db
